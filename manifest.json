{
  "manifest_version": 3,
  "name": "YouTube Looper - Save Segments & AB Repeat",
  "version": "1.0.4",
  "description": "Loop selected parts of YouTube videos, save segments, and set different playback speeds for each saved segment.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "YouTube Looper - Save Segments & AB Repeat",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
